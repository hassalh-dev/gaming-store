{# src/views/components/header/header.twig #}

{# ── Announcement Bar ── #}
<div class="announcement-bar">
  <span>🎮 شحن فوري على جميع المنتجات الرقمية | استخدم كود GAME10 للحصول على خصم 10%</span>
</div>

{# ── Main Header ── #}
<header class="site-header{% if theme.settings.header_is_sticky %} is-sticky{% endif %}"
        id="site-header">

  <div class="header-inner">

    {# Logo #}
    <a href="{{ store.url }}" class="header-logo">
      <img src="{{ store.logo|cdn(175) }}"
           alt="{{ store.name }}"
           loading="eager">
    </a>

    {# Navigation #}
    <nav class="header-nav">
      <salla-menu type="main"></salla-menu>
    </nav>

    {# Actions #}
    <div class="header-actions">
      <salla-search></salla-search>
      <salla-wishlist-button></salla-wishlist-button>
      <salla-cart-summary></salla-cart-summary>
      <salla-user-btn></salla-user-btn>
    </div>

    {# Mobile Toggle #}
    <button class="header-mobile-toggle" aria-label="القائمة">
      <i class="sicon-menu"></i>
    </button>

  </div>
</header>
