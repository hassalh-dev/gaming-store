{# src/views/components/footer/footer.twig #}

<footer class="site-footer">

  {# ── Footer Top ── #}
  <div class="footer-top">

    {# Brand Column #}
    <div class="footer-brand">
      <a href="{{ store.url }}" class="footer-logo">
        <img src="{{ store.logo|cdn(175) }}" alt="{{ store.name }}">
      </a>
      <p class="footer-desc">
        متجرك الأول لشحن ألعابك المفضلة — شحن فوري وآمن على مدار الساعة
      </p>
      <div class="footer-social">
        {% if store.social.twitter %}
          <a href="{{ store.social.twitter }}" target="_blank" aria-label="Twitter">
            <i class="sicon-twitter"></i>
          </a>
        {% endif %}
        {% if store.social.instagram %}
          <a href="{{ store.social.instagram }}" target="_blank" aria-label="Instagram">
            <i class="sicon-instagram"></i>
          </a>
        {% endif %}
        {% if store.social.snapchat %}
          <a href="{{ store.social.snapchat }}" target="_blank" aria-label="Snapchat">
            <i class="sicon-snapchat"></i>
          </a>
        {% endif %}
        {% if store.social.tiktok %}
          <a href="{{ store.social.tiktok }}" target="_blank" aria-label="TikTok">
            <i class="sicon-tiktok"></i>
          </a>
        {% endif %}
        {% if store.social.youtube %}
          <a href="{{ store.social.youtube }}" target="_blank" aria-label="YouTube">
            <i class="sicon-youtube"></i>
          </a>
        {% endif %}
      </div>
    </div>

    {# Links Column 1 #}
    <div class="footer-col">
      <h4 class="footer-col-title">روابط سريعة</h4>
      <ul class="footer-links">
        <li><a href="{{ store.url }}">الرئيسية</a></li>
        <li><a href="{{ store.url }}/store/products">المنتجات</a></li>
        <li><a href="{{ store.url }}/store/categories">التصنيفات</a></li>
        <li><a href="{{ store.url }}/page/about">من نحن</a></li>
      </ul>
    </div>

    {# Links Column 2 #}
    <div class="footer-col">
      <h4 class="footer-col-title">الدعم</h4>
      <ul class="footer-links">
        <li><a href="{{ store.url }}/page/contact">تواصل معنا</a></li>
        <li><a href="{{ store.url }}/page/privacy">سياسة الخصوصية</a></li>
        <li><a href="{{ store.url }}/page/terms">الشروط والأحكام</a></li>
        <li><a href="{{ store.url }}/customer/orders">طلباتي</a></li>
      </ul>
    </div>

    {# Newsletter Column #}
    <div class="footer-col">
      <h4 class="footer-col-title">النشرة البريدية</h4>
      <div class="footer-newsletter">
        <p>اشترك للحصول على أحدث العروض والتخفيضات</p>
        <div class="newsletter-form">
          <input type="email" placeholder="بريدك الإلكتروني">
          <button type="button">اشترك</button>
        </div>
      </div>
    </div>

  </div>

  {# ── Footer Bottom ── #}
  <div class="footer-bottom">
    <div class="footer-bottom-inner">
      <p class="footer-copy">
        © {{ "now"|date("Y") }} جميع الحقوق محفوظة لـ <span>{{ store.name }}</span>
      </p>
      <div class="footer-payment">
        <img src="{{ 'images/visa.svg'|asset }}" alt="Visa">
        <img src="{{ 'images/mastercard.svg'|asset }}" alt="Mastercard">
        <img src="{{ 'images/mada.svg'|asset }}" alt="Mada">
        <img src="{{ 'images/stc.svg'|asset }}" alt="STC Pay">
      </div>
    </div>
  </div>

</footer>