{# src/views/components/home/enhanced-slider.twig #}

<section class="hero" id="hero">

  {# Particles Canvas #}
  <canvas id="hero-particles" aria-hidden="true"></canvas>

  {# Background Image #}
  {% if section.background_image %}
    <div class="hero-bg-image"
         style="background-image: url({{ section.background_image|cdn(1920) }})">
    </div>
  {% endif %}

  {# Overlay #}
  <div class="hero-overlay" aria-hidden="true"></div>

  {# Content #}
  <div class="hero-content">

    <div style="max-width: 620px;">

      {# Label #}
      {% if section.label %}
        <span class="hero-label">
          🎮 {{ section.label }}
        </span>
      {% else %}
        <span class="hero-label">
          🎮 متجر الألعاب الرقمية
        </span>
      {% endif %}

      {# Title #}
      <h1 class="hero-title">
        {% if section.title %}
          {{ section.title }}
        {% else %}
          شحن فوري لـ <em>ألعابك المفضلة</em>
        {% endif %}
      </h1>

      {# Subtitle #}
      <p class="hero-subtitle">
        {% if section.subtitle %}
          {{ section.subtitle }}
        {% else %}
          اشحن PUBG، Free Fire، Fortnite وأكثر من 50 لعبة — بأسرع وقت وأفضل سعر
        {% endif %}
      </p>

      {# Actions #}
      <div class="hero-actions">
        <a href="{{ store.url }}/store/products"
           class="btn btn-primary btn-primary--pulse">
          🛒 تسوق الآن
        </a>
        <a href="{{ store.url }}/store/categories"
           class="btn btn-outline">
          📂 التصنيفات
        </a>
      </div>

    </div>

  </div>

  {# Bottom Border Shimmer #}
  <div class="hero-border" aria-hidden="true"></div>

</section>